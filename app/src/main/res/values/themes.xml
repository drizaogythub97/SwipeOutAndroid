<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SwipeOut" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">#FF0E0E14</item>
        <item name="android:navigationBarColor">#FF0E0E14</item>
    </style>

    <style name="Theme.SwipeOut.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0E0E14</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_round</item>
        <item name="postSplashScreenTheme">@style/Theme.SwipeOut</item>
    </style>
</resources>
